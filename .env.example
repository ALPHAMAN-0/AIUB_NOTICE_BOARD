# Copy this file to .env and fill in your values:  cp .env.example .env
# .env is git-ignored, so your real secrets stay out of the repo.
# Used by src/main.py (load_env_file) for local runs. In GitHub Actions
# these come from repo Secrets instead, not from this file.

# --- Telegram (required for real runs) ---
# From @BotFather after /newbot. Format: 123456789:ABCdef_GhIjkLmNoPqRsTuVwXyZ
TELEGRAM_BOT_TOKEN=
# Your numeric chat id. Get it from @userinfobot, or from
# https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot.
TELEGRAM_CHAT_ID=

# --- GitHub Models (optional locally; enables AI classification) ---
# Easiest:  GITHUB_TOKEN=$(gh auth token)
# Or a fine-grained PAT with the "models: read" permission.
# If left blank, the bot falls back to keyword-based classification.
GITHUB_TOKEN=

# --- Scraper proxy (optional) ---
# aiub.edu often drops traffic from outside Bangladesh (including GitHub's
# runners). Set a proxy URL with a Bangladesh exit to route ONLY the scrape
# through it (Telegram / GitHub Models calls stay direct).
# Format: http://user:pass@host:port  — in Actions, add it as the
# AIUB_PROXY repo secret instead.
AIUB_PROXY=
